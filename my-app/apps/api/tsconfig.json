{
  "extends": "@repo/typescript-config/nestjs.json",
  "compilerOptions": {
    // NestJS CLI'ın beklediği ayarlar
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*.spec.ts"]
}